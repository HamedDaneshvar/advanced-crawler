BASE_URL=https://example.com
LOGIN_URL=https://example.com/login
MAX_DEPTH=3
CONCURRENCY=1
DELAY_MIN_MS=2000
DELAY_MAX_MS=5000
MAX_RETRIES=3
OUTPUT_DIR=output
ASSETS_DIR=assets
DB_PATH=db/crawler.db
HEADFUL=true
BLOCK_SERVICE_WORKERS=true
# Use installed Google Chrome (Chrome Web Store works). Omit or use chromium for bundled Playwright browser.
PLAYWRIGHT_CHANNEL=chrome
# Optional: full path to chrome.exe if not found automatically
# BROWSER_EXECUTABLE_PATH=C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe
