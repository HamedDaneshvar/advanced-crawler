BASE_URL=https://example.com
LOGIN_URL=https://example.com/login
MAX_DEPTH=3
CONCURRENCY=1
DELAY_MIN_MS=2000
DELAY_MAX_MS=5000
MAX_RETRIES=3
OUTPUT_DIR=output
ASSETS_DIR=assets
DB_PATH=db/crawler.db
HEADFUL=true
BLOCK_SERVICE_WORKERS=true
# Use installed Google Chrome (Chrome Web Store works). Omit or use chromium for bundled Playwright browser.
PLAYWRIGHT_CHANNEL=chrome
# Optional: full path to chrome.exe if not found automatically
# BROWSER_EXECUTABLE_PATH=C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe

# Persistent Chrome profile (recommended for Web Store / extensions). Use a dedicated folder — NOT your daily Chrome profile.
PLAYWRIGHT_USER_DATA_DIR=.chrome-profile
# Helps Web Store installs when using a persistent profile (drops --enable-automation default arg).
PLAYWRIGHT_IGNORE_ENABLE_AUTOMATION=true
# Enables real Chromium sandbox so Playwright does NOT add --no-sandbox (removes Chrome yellow banner).
PLAYWRIGHT_CHROMIUM_SANDBOX=true
# Playwright injects --disable-extensions by default → Web Store shows "Installation is not enabled". Set true to allow extensions.
PLAYWRIGHT_ALLOW_EXTENSIONS=true
# Do not pass --disable-blink-features=AutomationControlled (removes Chrome’s warning about that flag; correct spelling is "features").
PLAYWRIGHT_OMIT_AUTOMATION_CONTROLLED_ARG=true
